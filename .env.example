# development | production | test (required)
NODE_ENV = development

APP_NAME =
# HOST and PORT are ignored on Vercel (Vercel manages the runtime listener automatically)
HOST = 0.0.0.0
PORT = 8080

# ─── Database ────────────────────────────────────────────────────────────────

DATABASE_URI = mongodb://127.0.0.1:27017/database_name

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate keys: ssh-keygen -t rsa -b 2048 -m PEM -f jwt.key
# Then base64-encode: base64 -i jwt.key && base64 -i jwt.key.pub

JWT_ACCESS_TOKEN_SECRET_PRIVATE =
JWT_ACCESS_TOKEN_SECRET_PUBLIC =
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES = 240

REFRESH_TOKEN_EXPIRATION_DAYS = 1
VERIFY_EMAIL_TOKEN_EXPIRATION_MINUTES = 60
RESET_PASSWORD_TOKEN_EXPIRATION_MINUTES = 30

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────

SMTP_HOST = smtp.googlemail.com
SMTP_PORT = 465
SMTP_USERNAME =
SMTP_PASSWORD =
EMAIL_FROM =

# ─── URLs & CORS ──────────────────────────────────────────────────────────────
# On Vercel, VERCEL_URL is auto-injected at runtime (e.g. your-project.vercel.app).
# Use it as a fallback for IMAGE_URL in production if not overriding manually.

FRONTEND_URL = http://localhost:3000
IMAGE_URL = http://localhost:8080/images

# Comma-separated origins for CORS, or * for all (avoid * in production).
# In production set this to your exact frontend domain(s), e.g.:
#   CORS_ORIGIN = https://your-app.vercel.app,https://yourdomain.com
CORS_ORIGIN = *

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Leave empty to disable "Login with Google"

GOOGLE_CLIENT_ID =
GOOGLE_CLIENT_SECRET =

# ─── Cloudinary (optional) ────────────────────────────────────────────────────
# Leave empty to use local image storage

CLOUDINARY_CLOUD_NAME =
CLOUDINARY_API_KEY =
CLOUDINARY_API_SECRET =

# ─── Seeding ──────────────────────────────────────────────────────────────────
# Set to true to seed permissions, roles, and (in development/test only) default users.
# NEVER enable in production with default passwords.

SEED_DATABASE = false
# Optional: when set (min 6 chars), all seed users use this password instead of
# the default dev passwords. Useful in CI/test environments.
# SEED_DEFAULT_PASSWORD =

# ─── Rate Limiting (optional) ─────────────────────────────────────────────────
# Vercel Functions scale automatically, but rate limits protect your DB and SMTP.
# Defaults: 15-min window, 100 global req, 20 auth req.

# RATE_LIMIT_WINDOW_MS = 900000
# RATE_LIMIT_MAX = 100
# AUTH_RATE_LIMIT_MAX = 20

# ─── Vercel Deployment Notes ──────────────────────────────────────────────────
# The following are automatically set by Vercel — do NOT define them manually:
#   VERCEL_URL        → the deployment URL (e.g. your-project.vercel.app)
#   VERCEL_ENV        → "production" | "preview" | "development"
#   VERCEL_REGION     → the region your function runs in (e.g. iad1)
#
# Recommended dashboard settings for this project:
#   • Enable Fluid Compute (Project Settings → Functions) for Express concurrency
#   • Set Function region close to your MongoDB cluster region
#   • Set CORS_ORIGIN to your exact frontend URL(s) in the Production environment
#   • Add all secrets via: Vercel Dashboard → Project Settings → Environment Variables
