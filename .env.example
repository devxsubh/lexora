# development | production | test (required)
NODE_ENV = development

APP_NAME =
HOST = 0.0.0.0
PORT = 8080

# Graceful shutdown: HTTP drain timeout (ms), then open sockets are destroyed. Default 10000.
# SHUTDOWN_GRACE_MS = 10000
# After HTTP closes, max wait (ms) for runBackgroundJob work. Default 15000.
# SHUTDOWN_BACKGROUND_DRAIN_MS = 15000

# Log timestamps timezone (e.g. Asia/Kolkata for IST). Leave empty for server local time.
# LOG_TZ = Asia/Kolkata

# ─── Database ────────────────────────────────────────────────────────────────

DATABASE_URI = mongodb://127.0.0.1:27017/database_name

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate keys: ssh-keygen -t rsa -b 2048 -m PEM -f jwt.key
# Then base64-encode: base64 -i jwt.key && base64 -i jwt.key.pub

JWT_ACCESS_TOKEN_SECRET_PRIVATE =
JWT_ACCESS_TOKEN_SECRET_PUBLIC =
# Optional: set to a stable string (e.g. v2026-03) — emitted as JWT `kid`; verification uses the public key above
# JWT_ACCESS_TOKEN_KEY_ID =
# Optional: previous public keys still accepting tokens, JSON map of kid -> base64(SPKI PEM), e.g. {"v2024-01":"<base64>"}
# JWT_ACCESS_TOKEN_PUBLIC_KEYS_JSON =
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES = 240

REFRESH_TOKEN_EXPIRATION_DAYS = 1
VERIFY_EMAIL_TOKEN_EXPIRATION_MINUTES = 60
RESET_PASSWORD_TOKEN_EXPIRATION_MINUTES = 30

# ─── Email (Resend) ───────────────────────────────────────────────────────────

RESEND_API_KEY =
EMAIL_FROM =

# ─── URLs & CORS ──────────────────────────────────────────────────────────────
# Set FRONTEND_URL and IMAGE_URL to your production frontend/backend URLs.

FRONTEND_URL = http://localhost:3000
IMAGE_URL = http://localhost:8080/images

# Comma-separated origins for CORS, or * for all (avoid * in production).
# In production set to your frontend domain(s), e.g.:
#   CORS_ORIGIN = https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN = *

# ─── Client (Next.js) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_ vars are inlined into the client bundle at build time.
NEXT_PUBLIC_BACKEND_URL = http://localhost:8080

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Leave empty to disable "Login with Google"

GOOGLE_CLIENT_ID =
GOOGLE_CLIENT_SECRET =

# ─── Cloudinary (optional) ────────────────────────────────────────────────────
# Leave empty to use local image storage

CLOUDINARY_CLOUD_NAME =
CLOUDINARY_API_KEY =
CLOUDINARY_API_SECRET =

# ─── Seeding ──────────────────────────────────────────────────────────────────
# Set to true to seed permissions, roles, and (in development/test only) default users.
# NEVER enable in production with default passwords.

SEED_DATABASE = false
# Optional: when set (min 6 chars), all seed users use this password instead of
# the default dev passwords. Useful in CI/test environments.
# SEED_DEFAULT_PASSWORD =

# ─── Rate Limiting (optional) ─────────────────────────────────────────────────
# Defaults: 15-min window, 100 global req, 20 auth req.

# RATE_LIMIT_WINDOW_MS = 900000
# RATE_LIMIT_MAX = 100
# AUTH_RATE_LIMIT_MAX = 20

# ─── API versioning / deprecation (optional) ─────────────────────────────────
# When migrating clients to /api/v2, set these so /api/v1 responses include RFC-style hints.
# API_V1_DEPRECATION_LINK = https://docs.example.com/api-migration
# API_V1_SUNSET = Wed, 11 Nov 2026 23:59:59 GMT

# ─── Google Gemini (optional) ────────────────────────────────────────────────
# Required for AI contract features. Leave empty to disable AI routes that need it.

# GEMINI_API_KEY =
# When true, GET /api/v1/health/external calls the Gemini API (uses quota). Default false = key present only.
# GEMINI_HEALTH_LIVE_PROBE = false

# ─── Observability (optional) ────────────────────────────────────────────────
# METRICS_ENABLED = true
# Exposes Prometheus text at GET /metrics (not rate-limited when enabled).
# SENTRY_DSN =

# ─── Render Deployment ───────────────────────────────────────────────────────
# Render auto-assigns PORT and injects it into the process.
# Keep HOST=0.0.0.0 and set NODE_ENV=production in Render dashboard.
# Use an external uptime monitor (UptimeRobot/Better Stack) to ping:
#   https://your-service-name.onrender.com/api/v1/health
# every 5-10 minutes. For deploy/orchestrator readiness use:
#   GET /api/v1/health/ready
