# development | production | test (required)
NODE_ENV = development

APP_NAME =
HOST = 0.0.0.0
PORT = 666

DATABASE_URI = mongodb://127.0.0.1:27017/database_name


# RS256 keys: generate with ssh-keygen, then base64-encode (see README)
JWT_ACCESS_TOKEN_SECRET_PRIVATE =
JWT_ACCESS_TOKEN_SECRET_PUBLIC =
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES = 240

REFRESH_TOKEN_EXPIRATION_DAYS = 1
VERIFY_EMAIL_TOKEN_EXPIRATION_MINUTES = 60
RESET_PASSWORD_TOKEN_EXPIRATION_MINUTES = 30

SMTP_HOST = smtp.googlemail.com
SMTP_PORT = 465
SMTP_USERNAME =
SMTP_PASSWORD =
EMAIL_FROM =

FRONTEND_URL = http://localhost:777
IMAGE_URL = http://localhost:666/images

# Comma-separated origins for CORS, or * for all (avoid * in production)
CORS_ORIGIN = *

# Google OAuth (optional – leave empty to disable “Login with Google”)
GOOGLE_CLIENT_ID =
GOOGLE_CLIENT_SECRET =

# Cloudinary (optional – leave empty to use local image storage)
CLOUDINARY_CLOUD_NAME =
CLOUDINARY_API_KEY =
CLOUDINARY_API_SECRET =

# Set to true to seed permissions, roles, and (in development/test only) default users. Never enable in production with default passwords.
SEED_DATABASE = false
# Optional: when set (min 6 chars), all seed users use this password instead of default dev passwords. Use in CI/test.
# SEED_DEFAULT_PASSWORD =

# Rate limits (optional; defaults: 15min window, 100 global, 20 auth)
# RATE_LIMIT_WINDOW_MS = 900000
# RATE_LIMIT_MAX = 100
# AUTH_RATE_LIMIT_MAX = 20
