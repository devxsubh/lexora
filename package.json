{
  "name": "lexora",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm run --parallel build",
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "lint": "pnpm run --parallel lint",
    "lint:client": "pnpm --filter client lint",
    "lint:server": "pnpm --filter server lint",
    "test": "pnpm --filter server test",
    "test:watch": "pnpm --filter server test:watch",
    "clean": "pnpm --filter '*' exec rm -rf node_modules dist .next && rm -rf node_modules"
  }
}
