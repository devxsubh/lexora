{
	"name": "backend-node-express",
	"version": "1.5.2",
	"private": true,
	"engines": {
		"node": "20.x"
	},
	"scripts": {
		"start": "npm run dev",
		"dev": "cross-env NODE_ENV=development nodemon --ext ts --watch src --exec \"node -r tsconfig-paths/register -r ts-node/register src/index.ts\"",
		"build": "tsc && tsc-alias -p tsconfig.json",
		"prod": "pm2-runtime start ecosystem.config.js --env production",
		"lint": "eslint src --ext .ts",
		"test": "jest",
		"test:watch": "jest --watch",
		"smoke": "npm run build && node scripts/smoke.js",
		"ci": "npm run lint && npm run test && npm run smoke"
	},
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"cloudinary": "^2.9.0",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"cross-env": "^7.0.3",
		"dotenv": "^10.0.0",
		"express": "^4.17.1",
		"express-rate-limit": "^5.3.0",
		"helmet": "^8.1.0",
		"http-status": "^1.8.1",
		"joi": "^17.4.2",
		"jsonwebtoken": "^8.5.1",
		"lodash": "^4.17.21",
		"moment": "^2.30.1",
		"mongoose": "^6.0.0",
		"morgan": "^1.10.1",
		"multer": "1.4.4-lts.1",
		"nodemailer": "^6.6.3",
		"passport": "^0.4.1",
		"passport-google-oauth20": "^2.0.0",
		"passport-jwt": "^4.0.0",
		"pm2": "^5.1.1",
		"sharp": "^0.29.3",
		"streamifier": "^0.1.1",
		"uuid": "^8.3.2",
		"validator": "^13.11.0",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/compression": "^1.7.5",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.0",
		"@types/jsonwebtoken": "^9.0.5",
		"@types/lodash": "^4.17.0",
		"@types/morgan": "^1.9.9",
		"@types/multer": "^1.4.11",
		"@types/node": "^20.10.0",
		"@types/nodemailer": "^6.4.14",
		"@types/passport": "^1.0.16",
		"@types/passport-google-oauth20": "^2.0.17",
		"@types/passport-jwt": "^4.0.0",
		"@types/supertest": "^2.0.16",
		"@types/uuid": "^9.0.7",
		"@types/validator": "^13.11.7",
		"@typescript-eslint/eslint-plugin": "^6.13.0",
		"@typescript-eslint/parser": "^6.13.0",
		"eslint": "^7.32.0",
		"eslint-config-airbnb-base": "^14.2.1",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-import": "^2.24.2",
		"eslint-plugin-prettier": "^4.0.0",
		"jest": "^29.7.0",
		"mongodb-memory-server": "^9.1.0",
		"nodemon": "^2.0.12",
		"prettier": "^2.4.0",
		"supertest": "^6.3.3",
		"ts-jest": "^29.1.0",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.3.0"
	}
}
